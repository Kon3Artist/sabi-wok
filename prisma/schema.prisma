generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  WORKER
  ADMIN
}

enum WorkerTier {
  BASIC
  PRO
  ELITE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CLIENT
  RESOLVED_WORKER
  CLOSED
}

enum AvailabilityStatus {
  AVAILABLE
  ON_JOB
  SCHEDULED
  OFFLINE
}

enum PricingMode {
  HOURLY
  QUOTE
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum JobRequestStatus {
  OPEN
  QUOTED
  BOOKED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CLIENT)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  workerProfile WorkerProfile?
  clientProfile ClientProfile?

  bookingsAsClient Booking[]    @relation("ClientBookings")
  reviewsGiven     Review[]     @relation("ReviewsGiven")
  notifications    Notification[]
  jobRequests      JobRequest[] @relation("ClientJobRequests")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WorkerProfile {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?            @db.Text
  location         String?
  serviceRadius    Int?               @default(10)
  pricingMode      PricingMode        @default(HOURLY)
  hourlyRate       Decimal?           @db.Decimal(10, 2)
  tier             WorkerTier         @default(BASIC)
  availability     AvailabilityStatus @default(AVAILABLE)
  isVerified       Boolean            @default(false)
  idDocumentUrl    String?
  registrationPaid Boolean            @default(false)
  registrationDate DateTime?
  totalJobsDone    Int                @default(0)
  avgRating        Float              @default(0)
  responseTimeMin  Int?
  subscriptionEnd  DateTime?
  paystackSubCode  String?
  bankCode         String?
  bankAccountNo    String?
  bankAccountName  String?
  paystackRecipientCode String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  skills           WorkerSkill[]
  bookings         Booking[]          @relation("WorkerBookings")
  jobRequests      JobRequest[]
  quotes           Quote[]
  availability_slots AvailabilitySlot[]
  reviewsReceived  Review[]      @relation("ReviewsReceived")
  portfolioImages  PortfolioImage[]
  featuredUntil    DateTime?
}

model ClientProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionEnd DateTime?
  paystackSubCode String?
  totalBookings   Int       @default(0)
  loyaltyPoints   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Category {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  icon        String?
  description String?
  skills      Skill[]
}

model Skill {
  id          String        @id @default(cuid())
  name        String        @unique
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  workers     WorkerSkill[]
}

model WorkerSkill {
  id             String        @id @default(cuid())
  workerProfileId String
  skillId        String
  yearsExp       Int?
  workerProfile  WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  skill          Skill         @relation(fields: [skillId], references: [id])

  @@unique([workerProfileId, skillId])
}

model AvailabilitySlot {
  id              String        @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  startTime       DateTime
  endTime         DateTime
  isBooked        Boolean       @default(false)
  bookingId       String?       @unique
}

model Booking {
  id              String        @id @default(cuid())
  clientId        String
  workerId        String
  client          User          @relation("ClientBookings", fields: [clientId], references: [id])
  worker          WorkerProfile @relation("WorkerBookings", fields: [workerId], references: [id])
  skillId         String?
  description     String        @db.Text
  scheduledStart  DateTime
  scheduledEnd    DateTime
  actualStart     DateTime?
  actualEnd       DateTime?
  status          BookingStatus @default(PENDING)
  agreedRate      Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  platformFee     Decimal       @db.Decimal(10, 2)
  workerPayout    Decimal       @db.Decimal(10, 2)
  address         String?
  notes           String?       @db.Text
  clientConfirmed Boolean       @default(false)
  jobRequestId    String?       @unique
  jobRequest      JobRequest?   @relation(fields: [jobRequestId], references: [id])
  quoteId         String?       @unique
  quote           Quote?        @relation(fields: [quoteId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  payment   Payment?
  review    Review?
  dispute   Dispute?
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("NGN")
  status            PaymentStatus @default(PENDING)
  paystackReference String?       @unique
  paystackAccessCode String?
  escrowedAt        DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?
  tipAmount         Decimal?      @db.Decimal(10, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Review {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  booking         Booking       @relation(fields: [bookingId], references: [id])
  reviewerId      String
  reviewer        User          @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  workerProfileId String
  workerProfile   WorkerProfile @relation("ReviewsReceived", fields: [workerProfileId], references: [id])
  rating          Int
  comment         String?       @db.Text
  createdAt       DateTime      @default(now())
}

model Dispute {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id])
  raisedBy    String
  reason      String        @db.Text
  evidence    String?       @db.Text
  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PortfolioImage {
  id              String        @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  url             String
  caption         String?
  createdAt       DateTime      @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model JobRequest {
  id              String           @id @default(cuid())
  clientId        String
  client          User             @relation("ClientJobRequests", fields: [clientId], references: [id])
  workerProfileId String
  worker          WorkerProfile    @relation(fields: [workerProfileId], references: [id])
  skillId         String?
  title           String
  description     String           @db.Text
  address         String
  photoUrls       String[]
  preferredDate   DateTime?
  status          JobRequestStatus @default(OPEN)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  quotes          Quote[]
  booking         Booking?
}

model Quote {
  id              String        @id @default(cuid())
  jobRequestId    String
  jobRequest      JobRequest    @relation(fields: [jobRequestId], references: [id])
  workerProfileId String
  worker          WorkerProfile @relation(fields: [workerProfileId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  breakdown       String?       @db.Text
  estimatedHours  Float?
  message         String?       @db.Text
  status          QuoteStatus   @default(SENT)
  expiresAt       DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime      @default(now())

  booking         Booking?
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
